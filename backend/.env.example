# ============================================================
#  Your Senior — Environment Template
#  Copy to .env and fill in your values. Never commit .env.
# ============================================================

# ─── Authentication ─────────────────────────────────────────
YOUR_SENIOR_API_KEY=change-me-to-a-strong-random-string

# ─── Anthropic (Claude LLM) ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
CLAUDE_MODEL=claude-sonnet-4-5

# ─── Google Drive ingestion (optional) ──────────────────────
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/service-account.json
GOOGLE_DRIVE_FOLDER_ID=

# ─── ChromaDB ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chromadb_store
CHROMA_COLLECTION_NAME=your_senior_docs

# ─── Server ─────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── RAG ────────────────────────────────────────────────────
CONFIDENCE_HIGH=0.75
CONFIDENCE_LOW=0.40
TOP_K_CHUNKS=5
MAX_CHUNK_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# ─── Admin ──────────────────────────────────────────────────
QUERY_LOG_MAX_ENTRIES=50
