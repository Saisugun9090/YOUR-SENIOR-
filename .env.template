# ============================================================
#  Your Senior — Environment Configuration Template
#  Copy this file to .env and fill in your values.
#  Never commit .env to version control.
# ============================================================

# ─── Authentication ─────────────────────────────────────────
# A strong random string — the only key that grants access to Your Senior
YOUR_SENIOR_API_KEY=change-me-to-a-strong-random-string

# ─── Anthropic (Claude LLM) ─────────────────────────────────
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-5

# ─── Google Drive (for document ingestion) ──────────────────
# Path to your Google Service Account JSON (for Drive access)
GOOGLE_SERVICE_ACCOUNT_JSON=./secrets/service-account.json

# Google Drive folder ID to ingest from (optional — leave blank to ingest root)
GOOGLE_DRIVE_FOLDER_ID=

# ─── ChromaDB ───────────────────────────────────────────────
CHROMA_PERSIST_DIR=/data/chroma
CHROMA_COLLECTION_NAME=your_senior_docs

# ─── Backend Server ─────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── RAG Configuration ──────────────────────────────────────
# Confidence thresholds (0.0 – 1.0)
# Above HIGH  → full answer with citations
# HIGH to LOW → partial answer with warning
# Below LOW   → "I don't have a reliable answer"
CONFIDENCE_HIGH=0.75
CONFIDENCE_LOW=0.40

# Number of chunks to retrieve per query
TOP_K_CHUNKS=5

# Semantic chunking: max tokens per chunk before falling back to fixed-size
MAX_CHUNK_TOKENS=512
CHUNK_OVERLAP_TOKENS=50

# ─── Admin / Logging ────────────────────────────────────────
# Max number of queries stored in the query log
QUERY_LOG_MAX_ENTRIES=50
